# ---------------------------------------------------------------------------
# Optional: Sanity write token
# ---------------------------------------------------------------------------
# Only needed if you're seeding the CMS or running write scripts. The
# read-only build-time fetcher does NOT need this — the Sanity project ID is
# hardcoded in src/sanity/client.js and the public dataset is anonymously
# readable.
#
# Generate at: https://www.sanity.io/manage/personal/project/e9pgmdfm/api
# Then run:    SANITY_WRITE_TOKEN=<token> node scripts/seed-cms.mjs
SANITY_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Vercel deploy hook URL
# ---------------------------------------------------------------------------
# Used by the Studio "Deploy" tool (sanity/tools/DeployTool.jsx) to trigger
# a production rebuild on demand. Replaces the auto-webhook so you decide
# when to deploy.
#
# 1. Vercel dashboard → Project Settings → Git → Deploy Hooks → Create Hook
#    (name "Studio Deploy", target branch `main`)
# 2. Copy the URL.
# 3. Set the variable in two places:
#    - Local dev: .env with VITE_ prefix so Vite picks it up
#    - Production: Vercel → Settings → Environment Variables →
#      add VITE_VERCEL_DEPLOY_HOOK_URL with the same value, then redeploy
#      once so the Studio bundle picks it up
VITE_VERCEL_DEPLOY_HOOK_URL=

# ---------------------------------------------------------------------------
# Optional: Sanity write token
# ---------------------------------------------------------------------------
# Only needed if you're seeding the CMS or running write scripts. The
# read-only build-time fetcher does NOT need this — the Sanity project ID is
# hardcoded in src/sanity/client.js and the public dataset is anonymously
# readable.
#
# Generate at: https://www.sanity.io/manage/personal/project/e9pgmdfm/api
# Then run:    SANITY_WRITE_TOKEN=<token> node scripts/seed-cms.mjs
SANITY_WRITE_TOKEN=

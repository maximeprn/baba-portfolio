{
  "name": "basile-deschamps-portfolio",
  "version": "1.0.0",
  "description": "Portfolio website for visual artist Basile Deschamps - Film & Photography",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/fetch-cms-content.mjs",
    "build": "vite build",
    "vercel-build": "bash scripts/vercel-build.sh",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "cms:seed": "node scripts/seed-cms.mjs",
    "cms:fetch": "node scripts/fetch-cms-content.mjs",
    "cms:watch": "node scripts/watch-cms.mjs",
    "cms:upload-hero-photos": "node scripts/upload-hero-photos.mjs",
    "cms:upload-photo-projects": "node scripts/upload-photo-projects.mjs",
    "cms:fix-photo-project-ranks": "node scripts/fix-photo-project-ranks.mjs",
    "cms:upload-films": "node scripts/upload-films.mjs",
    "cms:fix-film-ranks": "node scripts/fix-film-ranks.mjs",
    "cms:migrate-blob-to-mux": "node --env-file-if-exists=.env scripts/migrate-blob-to-mux.mjs",
    "studio:dev": "sanity dev",
    "studio:deploy": "sanity deploy"
  },
  "dependencies": {
    "@mux/mux-node": "^14.1.0",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^1.2.0",
    "@sanity/orderable-document-list": "^1.5.1",
    "@sanity/vision": "^4.22.0",
    "hls.js": "^1.6.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.22.0",
    "sanity": "^4.22.0",
    "sanity-plugin-mux-input": "^2.19.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vercel/blob": "^2.3.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
